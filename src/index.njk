---
layout: base.njk
---

{# ===== LOADING — Photo Montage (Faces + NYC Landmarks) ===== #}
<div class="loading-screen" aria-hidden="true">
  {# Interview face photos #}
  {% for interview in collections.interviews %}
  <img src="{{ interview.data.photo }}" alt="{{ interview.data.name }}" class="montage-photo montage-face" data-face="{{ loop.index0 }}">
  {% endfor %}
  {# NYC landmark photos — interleaved by JS #}
  <img src="/assets/images/nyc-brooklyn-bridge.jpg" alt="Brooklyn Bridge" class="montage-photo montage-landmark" data-landmark="0">
  <img src="/assets/images/nyc-times-square.jpg" alt="Statue of Liberty" class="montage-photo montage-landmark" data-landmark="1">
  <img src="/assets/images/nyc-subway.jpg" alt="Brooklyn Bridge at Night" class="montage-photo montage-landmark" data-landmark="2">
  <img src="/assets/images/nyc-skyline.jpg" alt="Manhattan Skyline" class="montage-photo montage-landmark" data-landmark="3">
  <div class="montage-dots"></div>
</div>

{# ===== NAVIGATION ===== #}
<nav class="nav" role="navigation">
  <a href="/">
    <img src="/assets/images/logo.webp" alt="{{ site.title }}" class="nav-logo">
  </a>
  <ul class="nav-links">
    <li><a href="#map-section">Map</a></li>
    <li><a href="#interviews">Interviews</a></li>
    <li><a href="#quiz">Quiz</a></li>
    <li><a href="#get-interviewed">Get Interviewed</a></li>
    <li><a href="#about">About</a></li>
  </ul>
</nav>

{# ===== LIVE NYC TICKER ===== #}
