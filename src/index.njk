    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-rats">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-bikes">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-noise">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-film">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-dogs">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-restaurants">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-pothole">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    {# duplicate set for seamless scroll loop #}
    <span class="ticker-item" id="ticker-weather2">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-rats2">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-bikes2">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-noise2">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-film2">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-dogs2">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-restaurants2">Loading...</span>
    <span class="ticker-sep">&bull;</span>
    <span class="ticker-item" id="ticker-pothole2">Loading...</span>
  </div>
</div>

{# ===== HERO ===== #}
<section class="hero" id="hero">
  <img src="/assets/images/logo.webp" alt="{{ site.title }}" class="hero-logo">
  <h1 class="hero-tagline">{{ site.tagline }}</h1>
  <p class="hero-subtitle">{{ site.subtitle }}</p>
  <div class="hero-ctas">
    <a href="#map-section" class="btn btn-primary">Explore the Map</a>
    <a href="{{ site.substackUrl }}" class="btn btn-secondary" target="_blank" rel="noopener">Read on Substack</a>
  </div>
</section>

{# ===== MAP SECTION ===== #}
<section class="map-section" id="map-section">
  <div class="map-header">
    <h2>Where we've <span>been</span></h2>
    <span class="map-header-sub">Interviews across NYC</span>
  </div>
  <div class="map-container">
    <div id="map" role="application" aria-label="Interactive map of NYC interview locations"></div>
    <div class="map-sidebar">
      <div class="map-sidebar-title">Find on Map</div>
      {% for interview in collections.interviews %}
      <div class="sidebar-card" data-index="{{ loop.index0 }}" tabindex="0" role="button" aria-label="View {{ interview.data.name }} on the map">
        {% if interview.data.photo %}
        <img src="{{ interview.data.photo }}" alt="{{ interview.data.name }}" class="sidebar-card-photo" loading="lazy">
        {% else %}
        <div class="sidebar-card-photo-placeholder">{{ interview.data.name | first }}</div>
        {% endif %}
        <div class="sidebar-card-info">
          <div class="sidebar-card-name">{{ interview.data.name }}</div>
          <div class="sidebar-card-place">{{ interview.data.placeName }}{% if interview.data.neighborhood %} &middot; {{ interview.data.neighborhood }}{% endif %}</div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# Embed interview data as JSON for the map JS #}
<script id="interview-data" type="application/json">
[
  {% for interview in collections.interviews %}
  {
    "name": {{ interview.data.name | dump | safe }},
    "quote": {{ interview.data.quote | dump | safe }},
    "bio": {{ interview.data.bio | dump | safe }},
    "placeName": {{ interview.data.placeName | dump | safe }},
    "placeType": {{ (interview.data.placeType or "") | dump | safe }},
    "latitude": {{ interview.data.latitude }},
    "longitude": {{ interview.data.longitude }},
    "neighborhood": {{ (interview.data.neighborhood or "") | dump | safe }},
    "substackUrl": {{ interview.data.substackUrl | dump | safe }},
    "date": {{ interview.data.date | dump | safe }},
    "photo": {{ (interview.data.photo or "") | dump | safe }}
  }{% if not loop.last %},{% endif %}
  {% endfor %}
]
</script>

{# ===== INTERVIEW GALLERY ===== #}
<section class="gallery-section" id="interviews">
  <div class="section-header">
    <div class="section-label">The Interviews</div>
    <div class="section-title">Stories from the city</div>
  </div>

  <div class="gallery-grid">
    {% for interview in collections.interviews %}
    <a href="{{ interview.data.substackUrl }}" class="interview-card" target="_blank" rel="noopener">
      {% if interview.data.photo %}
      <img src="{{ interview.data.photo }}" alt="{{ interview.data.name }}" class="card-photo" loading="lazy">
      {% else %}
      <div class="card-photo-placeholder">{{ interview.data.name | first }}</div>
      {% endif %}
      <div class="card-body">
        <div class="card-quote">"{{ interview.data.quote }}"</div>
        <div class="card-name">{{ interview.data.name }}</div>
        <div class="card-bio">{{ interview.data.bio }}</div>
        <div class="card-footer">
          {% if interview.data.neighborhood %}
          <span class="card-tag">{{ interview.data.neighborhood }}</span>
          {% endif %}
          <span>{{ interview.data.date | dateFormat("short") }}</span>
          <span class="card-arrow">&rarr;</span>
        </div>
      </div>
    </a>
    {% endfor %}
  </div>
</section>

{# ===== QUIZ ===== #}
<section class="quiz-section" id="quiz">
  <div class="quiz-inner">
    <div class="section-header" style="text-align:center">
      <div class="section-label">Take the Quiz</div>
      <div class="section-title" style="text-align:center">What Kind of New Yorker Are You?</div>
      <p style="color:var(--text-secondary);margin-top:0.5rem;font-size:0.92rem">7 questions. No wrong answers. Find out if you <em>know the score</em>.</p>
    </div>
    <div class="quiz-progress">
      <div class="quiz-progress-fill"></div>
    </div>
    <div class="quiz-counter">1 / 7</div>
    <div class="quiz-body"></div>
  </div>
</section>

{# ===== GET INTERVIEWED ===== #}
<section class="interview-request-section" id="get-interviewed">
  <div class="request-inner">
    <div class="section-header" style="text-align:center">
      <div class="section-label">Join the conversation</div>
      <div class="section-title" style="text-align:center">Got a story to tell?</div>
      <p style="color:var(--text-secondary);margin-top:0.5rem;font-size:0.95rem">Show us your New York. Isabel is always looking for the next interview.</p>
    </div>

    <div class="request-form-wrapper">
      <form class="request-form" name="interview-request" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <p class="sr-only">
          <label>Don't fill this out: <input name="bot-field"></label>
        </p>

        <div class="form-group">
          <label class="form-label" for="req-name">Your name</label>
          <input class="form-input" type="text" id="req-name" name="name" required placeholder="What do people call you?">
        </div>

        <div class="form-group">
          <label class="form-label" for="req-neighborhood">Neighborhood</label>
          <input class="form-input" type="text" id="req-neighborhood" name="neighborhood" required placeholder="Where in NYC do you live?">
        </div>

        <div class="form-group">
          <label class="form-label" for="req-years">How long have you lived in NYC?</label>
          <input class="form-input" type="text" id="req-years" name="years" required placeholder="Born here? Just moved? Somewhere in between?">
        </div>

        <div class="form-group">
          <label class="form-label" for="req-spot">Favorite spot in the city</label>
          <input class="form-input" type="text" id="req-spot" name="favorite-spot" required placeholder="Park, restaurant, bodega, rooftop — anything">
        </div>

        <div class="form-group">
          <label class="form-label" for="req-why">Why should Isabel interview you?</label>
          <textarea class="form-textarea" id="req-why" name="pitch" rows="4" placeholder="What's your New York story?"></textarea>
        </div>

        <div class="form-group">
          <label class="form-label" for="req-contact">How to reach you</label>
          <input class="form-input" type="text" id="req-contact" name="contact" required placeholder="Email or @instagram">
        </div>

        <button type="submit" class="btn btn-primary form-submit">Submit</button>
      </form>
    </div>
  </div>
</section>

{# ===== ABOUT ===== #}
<section class="about-section" id="about">
  <div class="section-label" style="text-align:center">About</div>
  <img src="/assets/images/isabel-1.jpg" alt="Isabel Togoh" class="about-photo">
  <p class="about-text">
    I'm Isabel, a journalist who interviews native and non-native New Yorkers about what makes this city so great — in their favorite NYC spots. Every week, a new Q&A lands in your inbox.
  </p>
  <div class="about-links">
    <a href="{{ site.substackUrl }}" class="btn btn-primary" target="_blank" rel="noopener">Subscribe on Substack</a>
    <a href="{{ site.googleMapsUrl }}" class="btn btn-secondary" target="_blank" rel="noopener">View on Google Maps</a>
  </div>
</section>

{# ===== WHY "KNOW THE SCORE" ===== #}
<section class="origin-section" id="the-name">
  <div class="origin-inner">
    <div class="origin-vinyl">
      <div class="vinyl-record">
        <div class="vinyl-label">
          <span class="vinyl-title">Native New Yorker</span>
          <span class="vinyl-artist">Odyssey &bull; 1977</span>
        </div>
      </div>
    </div>
    <div class="origin-text">
      <div class="section-label">Why "Know The Score"</div>
      <h3 class="origin-headline">It started with a song.</h3>
      <p class="origin-body">
        In 1977, Odyssey released "Native New Yorker" — a disco anthem that became the unofficial love letter to everyone who calls this city home. The chorus goes: <em>"You should know the score by now."</em>
      </p>
      <p class="origin-body">
        Knowing the score means knowing the city — the unwritten rules, the best slice spot, when to walk faster, where the locals actually go. That's what this newsletter is about: the people who <em>know the score</em> and the places that prove it.
      </p>
      <a href="https://www.youtube.com/watch?v=wCEmPnIJYes" class="btn btn-secondary origin-listen" target="_blank" rel="noopener">
        &#9654; Listen to the song
      </a>
    </div>
  </div>
</section>

